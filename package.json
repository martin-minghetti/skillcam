{
  "name": "skillcam",
  "version": "0.5.0",
  "description": "Turn successful AI agent runs into reusable markdown skills",
  "type": "module",
  "bin": {
    "skillcam": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "demo": "tsx scripts/demo.ts",
    "eval": "tsx eval/run.ts",
    "eval:judge": "tsx eval/run.ts --judge-only"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "claude-code",
    "codex",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martin-minghetti/skillcam.git"
  },
  "homepage": "https://github.com/martin-minghetti/skillcam#readme",
  "bugs": {
    "url": "https://github.com/martin-minghetti/skillcam/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "commander": "^14.0.3",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
